# WebCasa Environment Configuration
# This file is loaded by the systemd service

# Panel HTTP port
WEBCASA_PORT=39921

# Data directory (database, Caddyfile, backups)
WEBCASA_DATA_DIR=/var/lib/webcasa

# SQLite database path
WEBCASA_DB_PATH=/var/lib/webcasa/webcasa.db

# ============================================================================
# !! SECURITY-CRITICAL: YOU MUST REPLACE THE VALUE BELOW BEFORE DEPLOYING !!
#
# This JWT secret signs all authentication tokens. Leaving the placeholder
# value in place would let anyone forge admin sessions. WebCasa rejects this
# exact placeholder at startup and will REFUSE to run until you change it.
#
# Generate a strong secret, e.g.:
#   openssl rand -hex 32
# then paste the result as the value below (no quotes).
# ============================================================================
WEBCASA_JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING

# Path to Caddy binary
WEBCASA_CADDY_BIN=/usr/bin/caddy

# Path to generated Caddyfile
WEBCASA_CADDYFILE_PATH=/var/lib/webcasa/Caddyfile

# Log directory
WEBCASA_LOG_DIR=/var/log/webcasa

# Caddy admin API URL
WEBCASA_ADMIN_API=http://localhost:2019
